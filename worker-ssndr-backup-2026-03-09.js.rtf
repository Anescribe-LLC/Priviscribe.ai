\
\cf10 \cb3 \strokec10     function tick(ts) \{\cf4 \cb1 \strokec4 \
\cf10 \cb3 \strokec10       if (!running) return;\cf4 \cb1 \strokec4 \
\
\cf10 \cb3 \strokec10       const elapsed = (ts - startTs) / 1000;\cf4 \cb1 \strokec4 \
